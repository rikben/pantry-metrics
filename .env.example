# /.env.example
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=change-this-to-a-long-random-secret

DB_HOST=db
DB_PORT=3306
DB_NAME=pantry_metrics
DB_USER=pantry_metrics
DB_PASS=pantry_metrics_password
DB_ROOT_PASS=rootpassword

SESSION_NAME=pantry_metrics_session
SESSION_SECURE=false
SESSION_SAMESITE=Lax

# Reserved for future SSO/OIDC integration.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
